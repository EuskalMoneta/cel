{% for operation in operations %}

    <div class="d-flex justify-content-between align-items-center p-3" {% if loop.index is divisible by(2) %} style="background-color: #f9f9f9;" {% endif %}>

        <div class="d-flex flex-column align-items-center justify-content-center" style="min-width: 80px">
            <div>
                {{ operation.date| format_date('short', 'd MMM') }}
            </div>
            <div>
                {{ operation.date| format_date('short', 'Y') }}
            </div>
        </div>
        <div class="flex-grow-1 ml-3">
            <div class="main-color text-semi-bold">
                {% if operation.description is defined %}
                    {{ operation.description }}
                {% endif %}
            </div>
            <div class="secondary-color">
                {% if operation.relatedAccount.owner.display is defined %}
                    <span class="text-16"> {{ operation.relatedAccount.owner.display }}</span><br />
                {% endif %}

            </div>
        </div>
        <div class="d-flex">
            <div>
            </div>

            <div class="float-right ">

                {% if operation.amount > 0 %}
                    <div class="prix text-right green">+ {{ operation.amount | number_format(2, ',') }}</div>
                {% else %}
                    <div class="prix text-right">{{ operation.amount | number_format(2, ',') }}</div>
                {% endif %}

                {% if operation.type is defined %}
                    {{ operation.type.name | lower}}
                {% endif %}

            </div>
        </div>
    </div>
{% endfor %}
