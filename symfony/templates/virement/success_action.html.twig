{% extends 'base.html.twig' %}

{% block body %}
    <div class="container">
        <div class="row">
            <div class="col-sm-12 col-md-8 offset-md-2 mt-3 text-center">

                <div class="mb-4">
                    <div class="row mt-3" style="">
                        <div class="col text-center" style="">
                            <div style="border-radius: 5px;" class="text-white bg-eusko p-2">
                                <i class="fas fa-check mb-1 " style="font-size: 32px; margin-top: -5px; margin-right:10px;"></i>
                                <span class="threepermain text-semi-bold">{{ "Virement effectué" | trans  }}</span>
                            </div>
                            <br />
                            <h3 class="title-light">{{ "Destinataire" | trans }}</h3>
                            <h2 class="main-color mt-2">
                                {{ data["account_name"] }}
                            </h2>
                            <br />
                            <h3 class="title-light">{{ "Montant" | trans }}</h3>
                            <div class="main-color big-solde"> {{ data["amount"] }} eusko</div>
                            <br />
                            <h3 class="title-light">{{ "Libellé" | trans }}</h3>
                            <h2 class="main-color mt-2">
                                {{ data["description"] }}
                            </h2>
                        </div>

                    </div>

                    <div class="row mt-4">
                        <div class="col text-center">
                            <hr>
                            <form method="post">
                                <a href="{{ path('app_virement') }}" class="button-nav">{{ "virement.fin.autre" | trans }}</a>
                                <a href="{{ path('app_homepage') }}" style="margin-left: 15px;" class="button-nav"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
                                    </svg>
                                    <span class="ml-2">{{ "virement.fin.retour" | trans }}</span></a>
                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block js %}
{% endblock %}