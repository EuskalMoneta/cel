{% extends 'base.html.twig' %}

{% form_theme form 'bootstrap_4_layout.html.twig' %}

{% block menu_top %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-eusko static-top fixed-top">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_homepage') }}"><img src="{{ asset('images/logo-eusko-topbar.png') }}" alt="eusko logo" style="width: 60px;"></a>
            <div class="navbar-right">

                {% if app.user %}
                    <a href="{{ path('app_logout') }}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" fill="currentColor" class="bi bi-box-arrow-right" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/>
                            <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/>
                        </svg>
                        <br /> Quitter
                    </a>
                {% endif %}
            </div>
        </div>
    </nav>
{% endblock %}
{% block body %}
    <div class="container">
        <div class="row">
            <div class="col-12 col-md-6 offset-md-3 mt-4">

                <div class="mt-4">
                    <form method="post">

                        <h1 class="h3 mb-3 font-weight-normal">{{ "Lire les conditions générales d'Utilisation" | trans }}</h1>

                        <div class="text-center">
                            {% if is_granted('ROLE_PARTENAIRE') %}
                                <a href="{{ asset('images/CGU-Professionnels.pdf') }}" target="_blank" class="link"> CGU Professionnels</a>
                            {% else %}
                                <a href="{{ asset('images/CGU-Particuliers.pdf') }}" target="_blank" class="btn btn-outline-info"> CGU Particuliers</a>
                            {% endif %}
                        </div>
                        {{ form(form) }}


                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block menu_footer %}
{% endblock %}
